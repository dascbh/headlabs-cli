# Environment configuration for MCP cClassTrib

# URL base da API Conformidade Fácil
CFF_BASE_URL=https://cff.svrs.rs.gov.br/api/v1

# required · Caminho do certificado ICP-Brasil (PEM ou PFX)
CFF_CERT_PATH=

# Caminho da chave privada (se PEM separado)
CFF_CERT_KEY_PATH=

# secret · Senha do PFX ou chave privada
CFF_CERT_PASSPHRASE=

# TTL do cache em horas
CFF_CACHE_TTL_HORAS=24

# Caminho para persistência do snapshot em disco
CFF_CACHE_PATH=

# Timeout das requisições HTTP em milissegundos
CFF_TIMEOUT_MS=15000
